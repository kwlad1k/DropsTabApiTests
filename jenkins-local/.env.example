# Copy this file to ".env" and fill in real values:
#   cp .env.example .env
#
# .env is gitignored — your secrets stay local.

# Jenkins admin login (used at http://localhost:8080)
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=admin

# Public URL Jenkins should advertise in build emails / Telegram links.
# Keep as-is for local dev.
JENKINS_URL=http://localhost:8080/

# DropsTab account used by the test suite. The account must exist on
# api.icodrops.com. user.token can be obtained via:
#   curl -sS -X POST 'https://api.icodrops.com/portfolio/login' \
#        -H 'Content-Type: application/json' \
#        -d '{"email":"YOU","password":"YOU"}' | jq -r .accessToken
DROPSTAB_USER_NAME=pidiri207
DROPSTAB_USER_EMAIL=pidiri2073@inraud.com
DROPSTAB_USER_PASSWORD=1122336
DROPSTAB_USER_TOKEN=PASTE_FRESH_BEARER_TOKEN_HERE

# id.portfolio for the "special" test portfolio (must belong to the user above).
# Override the value committed to src/test/resources/config/portfolio.properties.
# Pre-create the portfolio via curl + seed at least one note, see jenkins-local/README.md.
DROPSTAB_PORTFOLIO_ID=2193621

# Telegram notifications — optional. Leave both empty to silently skip.
# Bot token from @BotFather, chat id from your Telegram bot's getUpdates response.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
